<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>ViaBill.Commerce</AssemblyName>
    <RootNamespace>ViaBill.Commerce</RootNamespace>
	<AddRazorSupportForMvc>true</AddRazorSupportForMvc>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="EPiServer.Commerce.Core"                   Version="14.15.3" />
	<PackageReference Include="EPiServer.Commerce.UI.CustomerService"     Version="14.15.3" />	
    <PackageReference Include="EPiServer.Framework"                       Version="12.21.7" />
    <PackageReference Include="Microsoft.Extensions.Http"                 Version="6.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="6.0.0" />
	<PackageReference Include="Microsoft.AspNetCore.Mvc.Razor"            Version="2.2.0" />
  </ItemGroup>

</Project>


