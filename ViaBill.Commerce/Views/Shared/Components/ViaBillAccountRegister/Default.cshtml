@model ViaBill.Commerce.Models.ViaBillRegisterViewModel
@{
    Layout = null;
}

@if (Model.IsAvailable)
{
    <div class="vbr-wrap">
        <div class="vbr-card">

            <div class="vbr-header">
                <div class="vbr-logo">
                    <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect width="32" height="32" rx="6" fill="#ffffff" fill-opacity="0.2" />
                        <path d="M8 9h4l4 10 4-10h4L16 24 8 9z" fill="#ffffff" />
                    </svg>
                </div>
                <div class="vbr-header-text">
                    <span class="vbr-brand">ViaBill</span>
                    <span class="vbr-sub">Optimizely Commerce</span>
                </div>
            </div>

            <h2 class="vbr-title">Create merchant account</h2>
            <p class="vbr-desc">Register your store with ViaBill to receive your API Key, Secret, and PriceTag script.</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="vbr-alert vbr-alert--error">@Model.ErrorMessage</div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="vbr-alert vbr-alert--success">@Model.SuccessMessage</div>
                <dl class="vbr-result">
                    <dt>API Key</dt>
                    <dd><code>@Model.ApiKey</code></dd>
                    <dt>Secret</dt>
                    <dd><code>@Model.Secret</code></dd>
                    <dt>PriceTag Script</dt>
                    <dd><code>@Model.PriceTagScript</code></dd>
                </dl>
            }
            else
            {
                <form method="post" action="/viabill-register" id="vbr-form" class="vbr-form">

                    @Html.AntiForgeryToken()

                    <div class="vbr-field">
                        <label for="vbr-name">Business Name</label>
                        <input type="text" id="vbr-name" name="Name"
                       value="@Model.Name" required autocomplete="organization" />
                    </div>

                    <div class="vbr-field">
                        <label for="vbr-email">Email address</label>
                        <input type="email" id="vbr-email" name="Email"
                       value="@Model.Email" required autocomplete="email" />
                    </div>

                    <div class="vbr-field">
                        <label for="vbr-url">Store URL</label>
                        <input type="text" id="vbr-url" name="Url"
                       value="@Model.Url" required placeholder="example.com" />
                    </div>

                    <div class="vbr-row">
                        <div class="vbr-field">
                            <label for="vbr-country">Country (ISO 2)</label>
                            <input type="text" id="vbr-country" name="Country"
                           value="@Model.Country" required
                           maxlength="2" placeholder="DK" autocomplete="country" />
                        </div>
                        <div class="vbr-field">
                            <label for="vbr-taxid">Tax ID <span class="vbr-opt"></span></label>
                            <input type="text" id="vbr-taxid" name="TaxId"
                           value="@Model.TaxId" required
                           maxlength="16" placeholder="DK12345678" />
                            <span id="vbr-taxid-error" class="vbr-field-error" style="display:none"></span>
                        </div>                        
                    </div>

                    <button type="submit" class="vbr-btn">Register with ViaBill</button>

                </form>
            }

        </div>
    </div>

    <style>
        .vbr-wrap {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 2rem 1rem;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        .vbr-card {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
            padding: 2rem;
            width: 100%;
            max-width: 420px;
        }

        .vbr-header {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            margin-bottom: 1.5rem;
        }

        .vbr-logo {
            width: 38px;
            height: 38px;
            background: #1a7a72;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .vbr-header-text {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .vbr-brand {
            font-size: 0.95rem;
            font-weight: 700;
            color: #111827;
        }

        .vbr-sub {
            font-size: 0.78rem;
            color: #6b7280;
        }

        .vbr-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #111827;
            margin: 0 0 0.4rem;
            line-height: 1.3;
        }

        .vbr-desc {
            font-size: 0.875rem;
            color: #6b7280;
            margin: 0 0 1.5rem;
            line-height: 1.5;
        }

        .vbr-form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .vbr-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }

        .vbr-field {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }

        .vbr-field label {
            font-size: 0.875rem;
            font-weight: 500;
            color: #374151;
        }

        .vbr-opt {
            font-weight: 400;
            color: #9ca3af;
        }

        .vbr-field input {
            padding: 0.6rem 0.85rem;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 0.9rem;
            color: #111827;
            background: #f9fafb;
            width: 100%;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

        .vbr-field input:focus {
            outline: none;
            border-color: #1a7a72;
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(26,122,114,0.12);
        }

        .vbr-btn {
            width: 100%;
            padding: 0.7rem 1rem;
            background: #1a7a72;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 0.25rem;
            transition: background 0.15s;
        }

        .vbr-btn:hover {
            background: #145f59;
        }

        .vbr-alert {
            padding: 0.75rem 1rem;
            border-radius: 7px;
            font-size: 0.875rem;
            margin-bottom: 1rem;
        }

        .vbr-alert--error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .vbr-alert--success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #6ee7b7;
        }

        .vbr-result {
            display: grid;
            grid-template-columns: max-content 1fr;
            gap: 0.4rem 1rem;
            font-size: 0.875rem;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 1rem;
        }

        .vbr-result dt {
            font-weight: 600;
            color: #6b7280;
        }

        .vbr-result dd {
            margin: 0;
            word-break: break-all;
        }

        .vbr-result code {
            font-size: 0.8rem;
            background: #f3f4f6;
            padding: 0.1rem 0.3rem;
            border-radius: 3px;
        }

        .vbr-field-error {
            font-size: 0.8rem;
            color: #991b1b;
            margin-top: 0.15rem;
        }

        @@media (max-width: 480px) {
            .vbr-row {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <script>
        (function () {
            var form = document.getElementById('vbr-form');
            var taxInput = document.getElementById('vbr-taxid');
            var countryInput = document.getElementById('vbr-country');
            var taxError = document.getElementById('vbr-taxid-error');

            function sanitizeTaxId(taxId, country) {
                // Strip spaces and dashes, trim whitespace
                taxId = taxId.replace(/[\s\-]/g, '').trim();
                country = country.trim().toUpperCase();

                if (!taxId) return '';   // optional — empty is fine

                if (country === 'ES') {
                    if (/^ES[0-9A-Z]+/.test(taxId)) return taxId;
                    if (/^[0-9A-Z]+/.test(taxId)) return 'ES' + taxId;
                    return '';
                }

                if (country === 'DK') {
                    if (/^DK[0-9]{8}$/.test(taxId)) return taxId;
                    if (/^[0-9]{8}$/.test(taxId)) return 'DK' + taxId;
                    return '';
                }

                // For other countries return as-is (no known format rule)
                return taxId;
            }

            form.addEventListener('submit', function (e) {
                var raw = taxInput.value;
                var country = countryInput.value;

                // Only validate if the user filled in a Tax ID
                if (!raw.trim()) return;

                var sanitized = sanitizeTaxId(raw, country);

                if (sanitized === '') {
                    e.preventDefault();
                    taxError.textContent = 'Invalid Tax ID format for country ' + country.toUpperCase() + '.';
                    taxError.style.display = 'block';
                    taxInput.focus();
                    return;
                }

                // Write the sanitized/prefixed value back before submitting
                taxInput.value = sanitized;
                taxError.style.display = 'none';
            });

            // Clear error on input change
            taxInput.addEventListener('input', function () {
                taxError.style.display = 'none';
            });
        })();
    </script>
}
